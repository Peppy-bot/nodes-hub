{
  peppy_schema: "node/v1",
  manifest: {
    name: "uvc_camera_controls_tests",
    tag: "v1",
    depends_on: {
      contracts: [
        {
          name: "rgb_camera",
          tag: "v1",
          link_id: "camera"
        },
      ]
    }
  },
  interfaces: {
    topics: {
      consumes: [
        {
          link_id: "camera",
          name: "video_stream"
        },
      ]
    },
    services: {
      consumes: [
        {
          link_id: "camera",
          name: "video_stream_info"
        },
        {
          link_id: "camera",
          name: "set_exposure"
        },
        {
          link_id: "camera",
          name: "set_white_balance"
        },
        {
          link_id: "camera",
          name: "set_gain"
        },
        {
          link_id: "camera",
          name: "set_brightness"
        },
        {
          link_id: "camera",
          name: "set_contrast"
        },
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
  }
}