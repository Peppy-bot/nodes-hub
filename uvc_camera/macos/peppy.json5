{
  peppy_schema: "node_v1",
  manifest: {
    name: "uvc_camera_macos",
    tag: "v1",
    labels: [
      "uvc",
      "camera",
      "usb",
    ]
  },
  execution: {
    language: "rust",
    run_cmd: [
      ""
    ],
    parameters: {
      device_path: "string",
      video: {
        frame_rate: "u16",
        resolution: {
          width: "u32",
          height: "u32",
        },
        camera_encoding: "string",
        topic_encoding: "string",
      },
    },
  },
  interfaces: {
    conforms_to: [
      {
        name: "uvc_camera",
        tag: "v1"
      },
    ],
  }
}