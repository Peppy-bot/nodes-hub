{
  peppy_schema: "node_v1",
  manifest: {
    name: "uvc_camera_linux",
    tag: "v1",
    labels: [
      "uvc",
      "camera",
      "usb",
    ]
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
      mount_paths: [
        // write permissions required for services
        "${parameters:device_path}:/dev/video0:rw"
      ]
    },
    parameters: {
      device_path: "string",
      video: {
        frame_rate: "u16",
        resolution: {
          width: "u32",
          height: "u32",
        },
        camera_encoding: "string",
        topic_encoding: "string",
      },
    },
  },
  interfaces: {
    conforms_to: [
      {
        name: "uvc_camera",
        tag: "v1"
      },
    ],
  }
}