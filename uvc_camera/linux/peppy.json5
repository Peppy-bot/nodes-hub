{
  peppy_schema: "node/v1",
  manifest: {
    name: "uvc_camera_linux",
    tag: "v1",
    implements: [
      { name: "rgb_camera", tag: "v1", link_id: "camera" },
    ],
    labels: [
      "uvc",
      "camera",
      "usb",
    ]
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
      mount_paths: [
        // write permissions required for services
        "${parameters:device_path}:/dev/video0:rw"
      ]
    },
    parameters: {
      device_path: "string",
      video: {
        frame_rate: "u16",
        resolution: {
          width: "u32",
          height: "u32",
        },
        camera_encoding: "string",
        topic_encoding: "string",
      },
    },
  },
  interfaces: {
    topics: {
      emits: [
        { link_id: "camera", name: "video_stream" },
      ],
    },
    services: {
      exposes: [
        { link_id: "camera", name: "video_stream_info" },
        { link_id: "camera", name: "set_exposure" },
        { link_id: "camera", name: "set_white_balance" },
        { link_id: "camera", name: "set_gain" },
        { link_id: "camera", name: "set_brightness" },
        { link_id: "camera", name: "set_contrast" },
      ],
    },
  }
}
