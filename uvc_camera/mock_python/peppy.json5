{
  peppy_schema: "node/v1",
  manifest: {
    name: "uvc_camera_python_mock",
    tag: "v1",
    labels: [
      "uvc",
      "camera"
    ]
  },
  execution: {
    language: "python",
    container: {
      def_file: "apptainer.def"
    },
    // Those are fake parameters supposed to emulate a real camera
    parameters: {
      device_path: {
        $type: "string",
        $default: "/dev/video0"
      },
      video: {
        frame_rate: {
          $type: "u16",
          $default: 30
        },
        resolution: {
          width: {
            $type: "u16",
            $default: 1920
          },
          height: {
            $type: "u16",
            $default: 1080
          },
        },
        camera_encoding: {
          $type: "string",
          $default: "mjpeg"
        },
        topic_encoding: {
          $type: "string",
          $default: "rgb8"
        },
      },
    },
  },
  interfaces: {
    conforms_to: [
      {
        name: "uvc_camera",
        tag: "v1"
      },
    ],
  }
}