{
  peppy_schema: "node/v1",
  manifest: {
    name: "uvc_camera_rust_mock",
    tag: "v1",
    implements: [
      { name: "uvc_camera", tag: "v1", link_id: "camera" },
    ],
    labels: [
      "uvc",
      "camera"
    ]
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    // Those are fake parameters supposed to emulate a real camera
    parameters: {
      device_path: {
        $type: "string",
        $default: "/dev/video0"
      },
      video: {
        frame_rate: {
          $type: "u16",
          $default: 30
        },
        resolution: {
          width: {
            $type: "u16",
            $default: 1920
          },
          height: {
            $type: "u16",
            $default: 1080
          },
        },
        camera_encoding: {
          $type: "string",
          $default: "mjpeg"
        },
        topic_encoding: {
          $type: "string",
          $default: "rgb8"
        },
      },
    },
  },
  interfaces: {
    topics: {
      emits: [
        { link_id: "camera", name: "video_stream" },
      ],
    },
    services: {
      exposes: [
        { link_id: "camera", name: "video_stream_info" },
        { link_id: "camera", name: "set_exposure" },
        { link_id: "camera", name: "set_white_balance" },
        { link_id: "camera", name: "set_gain" },
        { link_id: "camera", name: "set_brightness" },
        { link_id: "camera", name: "set_contrast" },
      ],
    },
  }
}
